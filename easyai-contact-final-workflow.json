    {
      "parameters": {
        "method": "POST",
        "url": "http://172.18.0.1:11434/api/chat",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama3.1:8b\",\n  \"stream\": false,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a professional customer support assistant for EasyAI — a self-hosted AI workspace platform. Write a warm, helpful, and concise reply (3-5 sentences) to the contact form message below. Do not invent pricing, dates, or promises. End with: Best regards, EasyAI Support Team\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Name: {{ $('Webhook').item.json.body.name }}\\nSubject: {{ $('Webhook').item.json.body.subject }}\\nMessage: {{ $('Webhook').item.json.body.message }}\"\n    }\n  ]\n}",
        "options": { "timeout": 60000 }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [-460, 0],
      "id": "ollama-request",
      "name": "Ollama AI Reply"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "extract-reply",
              "name": "ai_reply",
              "value": "={{ $json.message.content }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [-220, 0],
      "id": "extract-reply",
      "name": "Extract Reply"
    },
    {
      "parameters": {
        "fromEmail": "ecomercepos@murad.bd",
        "toEmail": "={{ $('Webhook').item.json.body.email }}",
        "subject": "=We received your enquiry — EasyAI",
        "html": "=<!DOCTYPE html>\n<html>\n<body style=\"margin:0;padding:0;background:#f1f5f9;font-family:'Segoe UI',Arial,sans-serif\">\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding:40px 20px\">\n<tr><td align=\"center\">\n<table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08)\">\n\n  <!-- Header -->\n  <tr>\n    <td style=\"background:linear-gradient(135deg,#4f46e5,#7c3aed);padding:32px 40px\">\n      <p style=\"margin:0 0 4px;color:rgba(255,255,255,0.7);font-size:12px;text-transform:uppercase;letter-spacing:1px\">EasyAI Platform</p>\n      <h1 style=\"margin:0;color:#ffffff;font-size:22px;font-weight:700\">✅ We Received Your Enquiry</h1>\n    </td>\n  </tr>\n\n  <!-- Body -->\n  <tr>\n    <td style=\"padding:36px 40px\">\n\n      <p style=\"margin:0 0 16px;color:#334155;font-size:15px;line-height:1.7;text-align:justify\">Dear <strong>{{ $('Webhook').item.json.body.name }}</strong>,</p>\n\n      <p style=\"margin:0 0 24px;color:#64748b;font-size:14px;line-height:1.8;text-align:justify\">Thank you for contacting <strong>EasyAI</strong>. We have received your enquiry regarding <strong>\"{{ $('Webhook').item.json.body.subject }}\"</strong> and our AI assistant has prepared an initial response for you. Our team will follow up within <strong>24 hours</strong> if further assistance is needed.</p>\n\n      <!-- AI Reply Box -->\n      <div style=\"background:#f5f3ff;border:1px solid #ddd6fe;border-radius:10px;padding:24px 28px;margin-bottom:28px\">\n        <p style=\"margin:0 0 14px;color:#7c3aed;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1px\">🤖 AI Assistant Response</p>\n        <p style=\"margin:0;color:#1e293b;font-size:14px;line-height:1.9;text-align:justify\">{{ $('Extract Reply').item.json.ai_reply }}</p>\n      </div>\n\n      <!-- Original Message Recap -->\n      <div style=\"background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:18px 22px;margin-bottom:28px\">\n        <p style=\"margin:0 0 10px;color:#94a3b8;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.8px\">Your Original Message</p>\n        <p style=\"margin:0 0 6px;color:#64748b;font-size:13px\"><strong>Subject:</strong> {{ $('Webhook').item.json.body.subject }}</p>\n        <p style=\"margin:0;color:#64748b;font-size:13px;line-height:1.7;text-align:justify;white-space:pre-wrap\">{{ $('Webhook').item.json.body.message }}</p>\n      </div>\n\n      <p style=\"margin:0;color:#64748b;font-size:14px;line-height:1.7;text-align:justify\">We appreciate you reaching out to us. Should you have any further questions or require immediate assistance, please feel free to reply to this email directly.</p>\n\n      <p style=\"margin:24px 0 0;color:#334155;font-size:14px;line-height:1.7\">Warm regards,<br><strong>EasyAI Support Team</strong></p>\n\n    </td>\n  </tr>\n\n  <!-- Footer -->\n  <tr>\n    <td style=\"background:#f8fafc;border-top:1px solid #e2e8f0;padding:20px 40px;text-align:center\">\n      <p style=\"margin:0;color:#94a3b8;font-size:12px\">EasyAI Platform &nbsp;·&nbsp; <a href=\"https://ai.murad.bd\" style=\"color:#6366f1;text-decoration:none\">ai.murad.bd</a> &nbsp;·&nbsp; Sent automatically via n8n</p>\n    </td>\n  </tr>\n\n</table>\n</td></tr>\n</table>\n</body>\n</html>",
        "options": {}
      },
      "type": "n8n-nodes-base.emailSend",
