    {
      "parameters": {
        "fromEmail": "ecomercepos@murad.bd",
        "toEmail": "murad@murad.bd",
        "subject": "=📬 New Contact: {{ $('Webhook').item.json.body.subject }}",
        "html": "=<!DOCTYPE html>\n<html>\n<body style=\"margin:0;padding:0;background:#f1f5f9;font-family:'Segoe UI',Arial,sans-serif\">\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding:40px 20px\">\n<tr><td align=\"center\">\n<table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08)\">\n\n  <!-- Header -->\n  <tr>\n    <td style=\"background:linear-gradient(135deg,#0f172a,#1e293b);padding:32px 40px\">\n      <p style=\"margin:0 0 4px;color:rgba(255,255,255,0.5);font-size:12px;text-transform:uppercase;letter-spacing:1px\">EasyAI Admin Notification</p>\n      <h1 style=\"margin:0;color:#ffffff;font-size:22px;font-weight:700\">📬 New Contact Form Submission</h1>\n    </td>\n  </tr>\n\n  <!-- Body -->\n  <tr>\n    <td style=\"padding:36px 40px\">\n\n      <!-- Contact Details -->\n      <p style=\"margin:0 0 14px;color:#64748b;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1px\">Contact Details</p>\n      <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #e2e8f0;border-radius:8px;overflow:hidden;margin-bottom:28px\">\n        <tr style=\"background:#f8fafc\">\n          <td style=\"padding:12px 18px;color:#94a3b8;font-size:13px;width:110px;border-bottom:1px solid #e2e8f0\">Name</td>\n          <td style=\"padding:12px 18px;color:#1e293b;font-size:14px;font-weight:600;border-bottom:1px solid #e2e8f0\">{{ $('Webhook').item.json.body.name }}</td>\n        </tr>\n        <tr>\n          <td style=\"padding:12px 18px;color:#94a3b8;font-size:13px;border-bottom:1px solid #e2e8f0\">Email</td>\n          <td style=\"padding:12px 18px;border-bottom:1px solid #e2e8f0\"><a href=\"mailto:{{ $('Webhook').item.json.body.email }}\" style=\"color:#4f46e5;font-size:14px;text-decoration:none\">{{ $('Webhook').item.json.body.email }}</a></td>\n        </tr>\n        <tr style=\"background:#f8fafc\">\n          <td style=\"padding:12px 18px;color:#94a3b8;font-size:13px;border-bottom:1px solid #e2e8f0\">Subject</td>\n          <td style=\"padding:12px 18px;color:#1e293b;font-size:14px;font-weight:600;border-bottom:1px solid #e2e8f0\">{{ $('Webhook').item.json.body.subject }}</td>\n        </tr>\n        <tr>\n          <td style=\"padding:12px 18px;color:#94a3b8;font-size:13px\">Received</td>\n          <td style=\"padding:12px 18px;color:#64748b;font-size:13px\">{{ $('Webhook').item.json.body.submitted_at }}</td>\n        </tr>\n      </table>\n\n      <!-- Message -->\n      <p style=\"margin:0 0 14px;color:#64748b;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1px\">Message</p>\n      <div style=\"background:#f8fafc;border:1px solid #e2e8f0;border-left:4px solid #4f46e5;border-radius:0 8px 8px 0;padding:16px 20px;margin-bottom:28px\">\n        <p style=\"margin:0;color:#334155;font-size:14px;line-height:1.8;text-align:justify;white-space:pre-wrap\">{{ $('Webhook').item.json.body.message }}</p>\n      </div>\n\n      <!-- AI Reply -->\n      <p style=\"margin:0 0 14px;color:#64748b;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1px\">🤖 AI Reply Sent to Visitor</p>\n      <div style=\"background:#f5f3ff;border:1px solid #ddd6fe;border-left:4px solid #7c3aed;border-radius:0 8px 8px 0;padding:16px 20px\">\n        <p style=\"margin:0;color:#4c1d95;font-size:14px;line-height:1.8;text-align:justify\">{{ $('Extract Reply').item.json.ai_reply }}</p>\n      </div>\n\n    </td>\n  </tr>\n\n  <!-- Footer -->\n  <tr>\n    <td style=\"background:#f8fafc;border-top:1px solid #e2e8f0;padding:20px 40px;text-align:center\">\n      <p style=\"margin:0;color:#94a3b8;font-size:12px\">EasyAI Platform &nbsp;·&nbsp; ai.murad.bd &nbsp;·&nbsp; Sent automatically via n8n</p>\n    </td>\n  </tr>\n\n</table>\n</td></tr>\n</table>\n</body>\n</html>",
        "options": {}
      },
